# Comma-separated list of repos to monitor for open PRs
TARGET_REPOS=scottgl9/skelm

# dry-run | real
# dry-run: write review markdown to ./reviews/<repo>__<pr>__<sha>.md
# real:    post via `gh pr review --comment`
POST_MODE=dry-run

# Pi backend (must match a model pi recognizes — see `pi --list-models`)
PI_PROVIDER=llamacpp
PI_MODEL=qwen36

# Where cloned repos live (per-pr isolated worktrees go inside)
REPO_CACHE_DIR=.skelm/repos
